# Database
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/newstruth

# Redis
REDIS_URL=redis://redis:6379/0

# Qwen API (阿里云 DashScope)
QWEN_API_KEY=your-qwen-api-key-here

# Baidu Search API
BAIDU_SEARCH_APP_ID=your-baidu-app-id
BAIDU_SEARCH_API_KEY=your-baidu-api-key
BAIDU_SEARCH_SECRET_KEY=your-baidu-secret-key

# Baidu AppBuilder API
BAIDU_APPBUILDER_API_KEY=your-baidu-appbuilder-api-key

# Tavily Search API
TAVILY_API_KEY=your-tavily-api-key

# App
APP_ENV=development
LOG_LEVEL=INFO
